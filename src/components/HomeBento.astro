---
import { formatDate, type BlogPost } from "../lib/posts";
import { getPostVisual } from "../lib/postVisuals";
import { tagSlug, withBase } from "../lib/site";

type TagCount = { tag: string; count: number };

type Props = {
  posts: BlogPost[];
  tags: TagCount[];
};

const { posts, tags } = Astro.props;
const [featured, ...restPosts] = posts;
const featureVisual = featured ? getPostVisual(featured.id) : null;
const slices = restPosts.slice(0, 3).map((post) => ({
  post,
  visual: getPostVisual(post.id),
}));
const topTags = tags.slice(0, 5);
const socialItems = [
  { label: "GitHub", status: "待补充" },
  { label: "X", status: "待补充" },
  { label: "Email", status: "待补充" },
];
---

<section class="section-pad latest-section" aria-labelledby="latest-title">
  <div class="container">
    <div class="latest-head">
      <div>
        <p class="section-kicker">Latest writing</p>
        <h2 class="eyeless-title" id="latest-title">
          近期文章
        </h2>
        <p class="lede">写作、阅读、构建系统，让思考在时间中沉淀。</p>
      </div>
      <a class="button button-secondary latest-browse" href={withBase("/posts/")}>全部文章</a>
    </div>

    <div class="latest-layout" aria-label="近期文章与连接">
      {
        featured && featureVisual ? (
          <article class="latest-feature">
            <a class="latest-feature-link" href={withBase(`/posts/${featured.id}/`)}>
              <div class="latest-feature-media">
                <img
                  src={featureVisual.image.src}
                  width={featureVisual.image.width}
                  height={featureVisual.image.height}
                  alt={featureVisual.alt}
                  decoding="async"
                />
              </div>
              <div class="latest-feature-copy">
                <p class="meta">{formatDate(featured.data.pubDate)} <span class="arrow-line">-></span></p>
                <h3>{featured.data.title}</h3>
                <p>{featured.data.description}</p>
              </div>
            </a>
          </article>
        ) : (
          <article class="latest-feature empty-state">
            <h3>还没有发布的文章。</h3>
            <p>写作开始时，这里会出现第一篇文章。</p>
          </article>
        )
      }

      <div class="latest-column">
        <div class="latest-list" aria-label="更多近期文章">
          {
            slices.map(({ post, visual }) => (
              <article class="latest-card">
                <a class="latest-card-link" href={withBase(`/posts/${post.id}/`)}>
                  <div class="latest-card-media">
                    <img
                      src={visual.image.src}
                      width={visual.image.width}
                      height={visual.image.height}
                      alt={visual.alt}
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                  <div class="latest-card-copy">
                    <p class="meta">{formatDate(post.data.pubDate)} <span class="arrow-line">-></span></p>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                  </div>
                </a>
              </article>
            ))
          }
        </div>

        <div class="latest-utility">
          <aside class="follow-panel" aria-labelledby="follow-title">
            <p class="section-kicker" id="follow-title">Follow us</p>
            <div class="social-list" aria-label="社交链接">
              {socialItems.map((item) => (
                <span class="social-chip is-disabled" aria-disabled="true">
                  <span>{item.label}</span>
                  <span class="meta">{item.status}</span>
                </span>
              ))}
              <a class="social-chip rss-link" href={withBase("/rss.xml")}>
                <svg class="rss-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M5 5.5c7.46 0 13.5 6.04 13.5 13.5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2.3" />
                  <path d="M5 11c4.42 0 8 3.58 8 8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2.3" />
                  <circle cx="6.2" cy="18" r="1.8" fill="currentColor" />
                </svg>
                <span>RSS</span>
              </a>
            </div>
          </aside>

          <aside class="topics-panel" aria-label="标签">
            <p class="section-kicker">Topics</p>
            <div class="topic-list">
              {
                topTags.map(({ tag, count }) => (
                  <a class="topic-link" href={withBase(`/tags/${tagSlug(tag)}/`)}>
                    <span>{tag}</span>
                    <span class="meta">{count}</span>
                  </a>
                ))
              }
            </div>
          </aside>
        </div>
      </div>
    </div>
  </div>
</section>
