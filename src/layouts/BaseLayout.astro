---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { SITE_DESCRIPTION, SITE_TITLE, absoluteUrl } from "../lib/site";

type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
  hideFooter?: boolean;
};

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  canonicalPath = Astro.url.pathname.replace(import.meta.env.BASE_URL.replace(/\/$/, ""), "") || "/",
  hideFooter = false,
} = Astro.props;

const pageTitle = title === SITE_TITLE ? SITE_TITLE : `${title} | ${SITE_TITLE}`;
const canonical = absoluteUrl(canonicalPath);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7fafc" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={import.meta.env.BASE_URL.replace(/\/$/, "") + "/favicon.svg"} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE_TITLE} RSS`} href={absoluteUrl("/rss.xml")} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <Header />
      <main>
        <slot />
      </main>
      {!hideFooter && <Footer />}
    </div>
  </body>
</html>
